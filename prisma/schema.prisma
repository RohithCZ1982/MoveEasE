// SwiftShift Movers - Prisma Schema for Neon Postgres

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  CONVERTED
  CLOSED
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

enum ItemUnit {
  NOS
  KG
  METER
  BOX
  ROLL
}

enum ServiceType {
  LOCAL_SHIFT
  INTERSTATE
  INTERNATIONAL
  CAR_TRANSPORT
  OFFICE_SHIFTING
  WAREHOUSE
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  role       UserRole @default(CUSTOMER)
  customerId String?  @unique
  customer   Customer? @relation(fields: [customerId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([email])
}

model Customer {
  id              String       @id @default(cuid())
  name            String
  mobile          String       @unique
  alternatePhone  String?
  email           String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  gstNumber       String?
  notes           String?
  user            User?
  quotations      Quotation[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([mobile])
  @@index([name])
}

model ItemMaster {
  id              String          @id @default(cuid())
  name            String
  unit            ItemUnit        @default(NOS)
  defaultRate     Decimal         @db.Decimal(10, 2)
  description     String?
  isActive        Boolean         @default(true)
  templateItems   TemplateItem[]
  quotationItems  QuotationItem[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Template {
  id          String         @id @default(cuid())
  name        String
  description String?
  isActive    Boolean        @default(true)
  items       TemplateItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model TemplateItem {
  id          String     @id @default(cuid())
  templateId  String
  template    Template   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  itemId      String
  item        ItemMaster @relation(fields: [itemId], references: [id])
  quantity    Decimal    @db.Decimal(10, 2)
  rate        Decimal    @db.Decimal(10, 2)
  createdAt   DateTime   @default(now())
}

model Service {
  id          String      @id @default(cuid())
  name        String
  type        ServiceType
  description String?
  baseRate    Decimal?    @db.Decimal(10, 2)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Truck {
  id           String   @id @default(cuid())
  registrationNo String @unique
  model        String
  capacity     String?
  isAvailable  Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Loader {
  id          String   @id @default(cuid())
  name        String
  mobile      String   @unique
  isAvailable Boolean  @default(true)
  dailyRate   Decimal? @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String          @unique
  customerId      String
  customer        Customer        @relation(fields: [customerId], references: [id])
  status          QuotationStatus @default(DRAFT)
  serviceType     ServiceType     @default(LOCAL_SHIFT)
  fromAddress     String?
  toAddress       String?
  shiftingDate    DateTime?
  items           QuotationItem[]
  laborCharges    Decimal         @default(0) @db.Decimal(10, 2)
  truckCharges    Decimal         @default(0) @db.Decimal(10, 2)
  insuranceAmount Decimal         @default(0) @db.Decimal(10, 2)
  packingCharges  Decimal         @default(0) @db.Decimal(10, 2)
  subtotal        Decimal         @default(0) @db.Decimal(10, 2)
  discountType    String          @default("amount")
  discountValue   Decimal         @default(0) @db.Decimal(10, 2)
  discountAmount  Decimal         @default(0) @db.Decimal(10, 2)
  gstRate         Decimal         @default(18) @db.Decimal(5, 2)
  gstAmount       Decimal         @default(0) @db.Decimal(10, 2)
  grandTotal      Decimal         @default(0) @db.Decimal(10, 2)
  notes           String?
  terms           String?
  validUntil      DateTime?
  invoice         Invoice?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([customerId])
  @@index([status])
}

model QuotationItem {
  id          String      @id @default(cuid())
  quotationId String
  quotation   Quotation   @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  itemId      String?
  item        ItemMaster? @relation(fields: [itemId], references: [id])
  customName  String?
  unit        ItemUnit    @default(NOS)
  quantity    Decimal     @db.Decimal(10, 2)
  rate        Decimal     @db.Decimal(10, 2)
  amount      Decimal     @db.Decimal(10, 2)
  createdAt   DateTime    @default(now())
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  quotationId   String        @unique
  quotation     Quotation     @relation(fields: [quotationId], references: [id])
  status        InvoiceStatus @default(UNPAID)
  items         InvoiceItem[]
  laborCharges  Decimal       @default(0) @db.Decimal(10, 2)
  truckCharges  Decimal       @default(0) @db.Decimal(10, 2)
  insuranceAmount Decimal     @default(0) @db.Decimal(10, 2)
  packingCharges  Decimal     @default(0) @db.Decimal(10, 2)
  subtotal      Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount Decimal      @default(0) @db.Decimal(10, 2)
  gstAmount     Decimal       @default(0) @db.Decimal(10, 2)
  grandTotal    Decimal       @default(0) @db.Decimal(10, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(10, 2)
  dueAmount     Decimal       @default(0) @db.Decimal(10, 2)
  paymentDate   DateTime?
  paymentMode   String?
  notes         String?
  dueDate       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

model InvoiceItem {
  id          String     @id @default(cuid())
  invoiceId   String
  invoice     Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  customName  String?
  unit        ItemUnit   @default(NOS)
  quantity    Decimal    @db.Decimal(10, 2)
  rate        Decimal    @db.Decimal(10, 2)
  amount      Decimal    @db.Decimal(10, 2)
  createdAt   DateTime   @default(now())
}
